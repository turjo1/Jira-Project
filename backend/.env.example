ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=mysql+aiomysql://app:app@mysql:3306/jira_analytics
REDIS_URL=redis://redis:6379/0

# 32+ char secret — rotate via K8s Secret in prod
JWT_SIGNING_KEY=replace-with-strong-random-32-bytes
AES_ENCRYPTION_KEY=replace-with-32-byte-key-base64-or-raw

JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/auth/callback

RATE_LIMIT_PER_MINUTE=1000
CORS_ORIGINS=["http://localhost:3000"]
