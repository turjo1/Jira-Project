# IMPORTANT: This is a template file. DO NOT commit with real secrets.
# Generate real secrets and store them in your secret management system.
#
# To create the actual secrets:
#
# 1. Generate JWT secret:
#    kubectl -n jira-analytics create secret generic jwt-secret \
#      --from-literal=key=$(openssl rand -hex 32)
#
# 2. Generate MySQL passwords:
#    kubectl -n jira-analytics create secret generic mysql-credentials \
#      --from-literal=root-password=$(openssl rand -hex 16) \
#      --from-literal=jira-password=$(openssl rand -hex 16)
#
# 3. Create Jira OAuth credentials:
#    kubectl -n jira-analytics create secret generic jira-oauth \
#      --from-literal=client-id=YOUR_JIRA_CLIENT_ID \
#      --from-literal=client-secret=YOUR_JIRA_CLIENT_SECRET
#
# 4. Create TLS certificate (if using cert-manager, it auto-creates this):
#    kubectl -n jira-analytics create secret tls tls-jira-analytics \
#      --cert=path/to/cert.crt \
#      --key=path/to/key.key
#
# OR use this template as reference and replace values:

apiVersion: v1
kind: Secret
metadata:
  name: jwt-secret
  namespace: jira-analytics
  labels:
    app: jira-analytics
    component: auth
type: Opaque
data:
  # Generate with: openssl rand -hex 32 | base64
  key: BASE64_ENCODED_JWT_SECRET_HERE
---
apiVersion: v1
kind: Secret
metadata:
  name: mysql-credentials
  namespace: jira-analytics
  labels:
    app: jira-analytics
    component: database
type: Opaque
data:
  # Generate with: echo -n "password" | base64
  root-password: BASE64_ENCODED_ROOT_PASSWORD
  jira-password: BASE64_ENCODED_JIRA_PASSWORD
  jira-username: amlyYQ==  # base64 for "jira"
---
apiVersion: v1
kind: Secret
metadata:
  name: jira-oauth-credentials
  namespace: jira-analytics
  labels:
    app: jira-analytics
    component: auth
type: Opaque
data:
  # From your Jira OAuth2 app registration
  # Generate with: echo -n "value" | base64
  client-id: BASE64_ENCODED_CLIENT_ID
  client-secret: BASE64_ENCODED_CLIENT_SECRET
---
apiVersion: v1
kind: Secret
metadata:
  name: tls-jira-analytics
  namespace: jira-analytics
  labels:
    app: jira-analytics
type: kubernetes.io/tls
data:
  # These are auto-generated by cert-manager if using Let's Encrypt
  # Otherwise, provide your own TLS certificate and key
  # tls.crt: BASE64_ENCODED_CERTIFICATE
  # tls.key: BASE64_ENCODED_PRIVATE_KEY
